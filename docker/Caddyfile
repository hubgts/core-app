# Reverse proxy public + HTTPS automatique (Let's Encrypt).
# Caddy obtient et renouvelle le certificat tout seul ; HTTP est redirigé
# vers HTTPS automatiquement. Les certificats sont persistés dans le volume
# caddy_data (voir docker-compose.prod.yml).

# Domaine principal : sert l'application (frontend nginx interne).
emiliengantois.fr {
	# Mot de passe d'accès au site (identifiant + hash bcrypt).
	# Définis dans docker/.env.prod (BASIC_AUTH_USER / BASIC_AUTH_HASH),
	# jamais en clair dans le repo public.
	basic_auth {
		{env.BASIC_AUTH_USER} {env.BASIC_AUTH_HASH}
	}

	reverse_proxy frontend:80
}

# www -> redirige vers le domaine principal.
www.emiliengantois.fr {
	redir https://emiliengantois.fr{uri} permanent
}
