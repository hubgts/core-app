# Variables d'environnement de PRODUCTION.
# Copier en docker/.env.prod et renseigner de vraies valeurs (NE PAS committer).
#   cp docker/.env.prod.example docker/.env.prod

# Base de données PostgreSQL
DB_USER=progression
DB_PASSWORD=change-moi-mot-de-passe-fort
DB_NAME=progression

# L'entrée publique (ports 80/443 + HTTPS) est gérée par Caddy. Le domaine et
# l'email Let's Encrypt se configurent dans docker/Caddyfile, pas ici.

# Accès au site (HTTP Basic Auth, géré par Caddy).
# Générer le hash :  docker exec -it core-app-prod-caddy caddy hash-password
# IMPORTANT : dans le hash ci-dessous, CHAQUE $ doit être DOUBLÉ en $$
# (sinon docker compose tronque la valeur). Ex. $2a$14$xxx -> $$2a$$14$$xxx
BASIC_AUTH_USER=emilien
BASIC_AUTH_HASH=$$2a$$14$$remplace-moi-par-le-hash-avec-dollars-doubles
