# Configuration du backend en production (installation native).
# Copier vers /etc/core-app/backend.env (hors dépôt) et renseigner les vraies
# valeurs, puis : sudo systemctl restart core-app-backend
#
#   sudo mkdir -p /etc/core-app
#   sudo cp deploy/backend.env.example /etc/core-app/backend.env
#   sudo nano /etc/core-app/backend.env
#   sudo chmod 600 /etc/core-app/backend.env

NODE_ENV=production
PORT=3000

# PostgreSQL local (installé sur la même machine)
DB_HOST=localhost
DB_PORT=5432
DB_USER=sunday
DB_PASSWORD=change-moi-mot-de-passe-fort
DB_NAME=core
